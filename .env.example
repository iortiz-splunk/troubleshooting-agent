# LLM provider (optional): ollama | openai | azure_openai
# If unset, uses openai when OPENAI_API_KEY + OPENAI_BASE_URL are set; otherwise ollama.
# LLM_PROVIDER=openai

# Ollama (default LLM provider)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# LLM_TEMPERATURE=0.2
# OLLAMA_TEMPERATURE=0.2   # alias for LLM_TEMPERATURE

# OpenAI-compatible API (LiteLLM proxy, OpenAI.com, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://lite-llm-proxy.example.com/v1
OPENAI_MODEL_NAME=gpt-4.1-mini

# Azure OpenAI native client (when LLM_PROVIDER=azure_openai)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-10-21

# Splunk MCP — see README.md "Splunk MCP setup" (mcp-doctor, then chat)
#
# Splunk Observability Cloud (o11y tools on Splunk Cloud MCP gateway)
# Auth: X-SF-REALM + X-SF-TOKEN only (not Splunk Cloud Bearer below)
# ENABLE_SPLUNK_O11Y=true
# SPLUNK_O11Y_GATEWAY_URL=https://region-pdx10.api.scs.splunk.com/system/mcp-gateway/v1/
# SPLUNK_O11Y_REALM=us1
# SPLUNK_O11Y_API_TOKEN=your-observability-api-token
# SPLUNK_O11Y_TOOL_PREFIX=o11y_

# Splunk Cloud MCP server (platform / logs — Bearer + tenant, not o11y-only auth)
# ENABLE_SPLUNK_CLOUD_MCP=true
# SPLUNK_CLOUD_MCP_URL=https://region-pdx10.api.scs.splunk.com/system/mcp-gateway/v1/
# SPLUNK_CLOUD_MCP_BEARER_TOKEN=your-splunk-cloud-mcp-jwt
# SPLUNK_CLOUD_MCP_TENANT=your-splunk-tenant-name

# Splunk Enterprise MCP (on-prem)
# ENABLE_SPLUNK_MCP=true
# SPLUNK_MCP_URL=https://your-splunk-host:8089/services/mcp
# SPLUNK_MCP_BEARER_TOKEN=your-bearer-token

# MCP transport command (default: npx)
# MCP_NPX_COMMAND=npx

# Slack demo — see README.md "Slack demo setup"
# ENABLE_SLACK=true
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...
# SLACK_ALERTS_CHANNEL_NAME=splunk-observability-alerts-1
# SLACK_ALERTS_CHANNEL_ID=        # optional; use if name lookup fails

# Agent logging trace (terminal)
# AGENT_LOG_TRACE=true
# AGENT_LOG_DEBUG=false
# LOG_FORMAT=text

# Splunk OTel APM (direct ingest — separate from SPLUNK_O11Y_API_TOKEN)
# ENABLE_SPLUNK_OTEL=true
# OTEL_SERVICE_NAME=troubleshooting-agent
# SPLUNK_ACCESS_TOKEN=              # Splunk ingest token for OTel
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo

# Galileo agent observability
# ENABLE_GALILEO=true
# GALILEO_API_KEY=
# GALILEO_PROJECT=troubleshooting-agent
# GALILEO_LOG_STREAM=slack-investigations
